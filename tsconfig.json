{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@db/*": ["./prisma/*"],
      "antd": ["./src/lib/antd-compat/index.tsx"],
      "antd/es/upload": ["./src/lib/antd-compat/upload.ts"],
      "antd/es/form/FormItem": ["./src/lib/antd-compat/form-item.tsx"],
      "@ant-design/icons": ["./src/lib/antd-compat/icons.tsx"]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
